# Copy this file to .env and fill in real values before running

# A long random string used to sign JWT tokens. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me

# PostgreSQL for production, SQLite for local dev
DATABASE_URL=sqlite:///./gitclone.db
# DATABASE_URL=postgresql://gitclone:gitclone@localhost:5432/gitclone

# Path to the directory where bare git repositories are stored
REPOS_DIR=repos

# Path to Jinja2 HTML templates (relative to where uvicorn is run)
TEMPLATES_DIR=frontend/templates
