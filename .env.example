# Copy to .env and fill in values before running

# REQUIRED — no default; app will refuse to start without this
SECRET_KEY=replace-with-a-long-random-string

# Database
DATABASE_URL=postgresql://gitclone:gitclone@postgres:5432/gitclone

# Storage
REPOS_DIR=/repos
TEMPLATES_DIR=/app/frontend/templates

# CORS origins (comma-separated, leave empty for no CORS)
CORS_ORIGINS=[]

# Token lifetime in minutes (default 1440 = 24h)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Sentry DSN for error monitoring (leave empty to disable)
# SENTRY_DSN=
